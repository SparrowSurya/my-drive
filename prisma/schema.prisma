// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DB_URL")
}

model User {
  id Int @id @default(autoincrement())

  name         String  @default("")
  email        String  @unique
  password     String?
  authProvider String?
  profilePic   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  folders    Folder[]
  activities Activity[]

  @@map("users")
}

model Folder {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: NoAction)

  name    String
  isRoot  Boolean  @default(false)
  starred Boolean?

  files    File[]
  children Hierarchy[] @relation("FolderAsParent")
  parent   Hierarchy?  @relation("FolderAsChild")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  directDelete Boolean?

  activities Activity[]

  @@map("folders")
}

model Hierarchy {
  id Int @id @default(autoincrement())

  folderId Int    @unique
  folder   Folder @relation("FolderAsChild", fields: [folderId], references: [id])

  parentId Int
  parent   Folder @relation("FolderAsParent", fields: [parentId], references: [id])

  @@unique([parentId, folderId])
  @@map("hierarchy")
}

model File {
  id Int @id @default(autoincrement())

  folderId Int
  folder   Folder @relation(fields: [folderId], references: [id], onDelete: NoAction)

  name     String
  size     Int
  mimeType String   @default("")
  data     Bytes
  starred  Boolean?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  directDelete Boolean?

  activities Activity[]

  @@unique([name, folderId])
  @@map("files")
}

model Activity {
  id Int @id @default(autoincrement())

  actorId Int
  actor   User @relation(fields: [actorId], references: [id], onDelete: NoAction)

  name String

  fileId Int?
  file   File? @relation(fields: [fileId], references: [id], onDelete: Cascade)

  folderId Int?
  folder   Folder? @relation(fields: [folderId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("activities")
}
